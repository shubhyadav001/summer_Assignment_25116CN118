//Write a program to Create student record management system.

#include <stdio.h>
#include <string.h>

struct Student {
    int roll;
    char name[50];
    float marks;
};

int main() {
    struct Student students[100];
    int n = 0, choice, searchRoll, i, found;

    do {
        printf("\n===== Student Record Management System =====\n");
        printf("1. Add Student Record\n");
        printf("2. Display Student Records\n");
        printf("3. Search Student Record\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                printf("\nEnter Roll Number: ");
                scanf("%d", &students[n].roll);

                printf("Enter Name: ");
                scanf("%s", students[n].name);

                printf("Enter Marks: ");
                scanf("%f", &students[n].marks);

                n++;
                printf("Student record added successfully!\n");
                break;

            case 2:
                if (n == 0) {
                    printf("No records available.\n");
                } else {
                    printf("\nStudent Records:\n");
                    for (i = 0; i < n; i++) {
                        printf("\nRoll No: %d", students[i].roll);
                        printf("\nName: %s", students[i].name);
                        printf("\nMarks: %.2f\n", students[i].marks);
                    }
                }
                break;

            case 3:
                printf("\nEnter Roll Number to search: ");
                scanf("%d", &searchRoll);

                found = 0;

                for (i = 0; i < n; i++) {
                    if (students[i].roll == searchRoll) {
                        printf("\nRecord Found:");
                        printf("\nRoll No: %d", students[i].roll);
                        printf("\nName: %s", students[i].name);
                        printf("\nMarks: %.2f\n", students[i].marks);
                        found = 1;
                        break;
                    }
                }

                if (!found)
                    printf("Student record not found.\n");

                break;

            case 4:
                printf("Exiting Student Record System...\n");
                break;

            default:
                printf("Invalid choice!\n");
        }

    } while(choice != 4);

    return 0;
}